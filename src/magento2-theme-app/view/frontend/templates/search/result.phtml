?>
<div class="search result">
    <div class="block search products">
        <div class="title h2"><?= $block->escapeHtml(__('Featured products for "%1"', $block->getSearchTerm())) ?></div>
        <div class="content">
            <?= $block->getLayout()->createBlock(
                \Magento\Catalog\Block\Product\ListProduct::class
            )->setProducts(
                $block->getProducts()
            )->setContext(
                'fishpig.ajax.search'
            )->setTemplate(
                'Magento_Catalog::product/list.phtml'
            )->setUseContainer(
                false
            )->toHtml() ?>
        </div>
    </div>
    <div class="block search terms">
        <div class="title h2"><?= $block->escapeHtml(__('Related terms')) ?></div>
        <ul>
            <?php foreach ($block->getRecommendations() as $recommendation): ?>
                <li>
                    <a href="<?= $block->escapeUrl($block->getRecommendationUrl($recommendation)) ?>"><?= $block->escapeHtml($recommendation->getQueryText()) ?> (<?= (int)$recommendation->getResultsCount() ?>)</a>
                </li>
            <?php endforeach; ?>
        </ul>
        <a href="<?= $block->escapeUrl($block->getViewAllResultsUrl()) ?>" class="view-all">See all results</a>
    </div>
</div>